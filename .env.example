# === Widźwięk — przykładowa konfiguracja ===
# Skopiuj do worker/.env (backend) i web/.env.local (frontend). NIE commituj .env.

# --- Worker (Python / FastAPI) ---
WIDZWIEK_HOST=127.0.0.1
WIDZWIEK_PORT=8000
# CORS: skąd frontend może wołać API (lokalnie Next.js dev)
WIDZWIEK_CORS_ORIGINS=http://localhost:3000

# Tryb pipeline: mock = symulacja (bez kluczy); api = realna transkrypcja
PIPELINE_MODE=mock

# OpenAI (wymagane tylko dla PIPELINE_MODE=api) — klucz TYLKO w .env, nigdy w kodzie
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
# HUGGINGFACE_TOKEN=        # TBD: diaryzacja (pyannote)

# Nadpisania per-etap (zaawansowane, opcjonalne) — domyślnie wynikają z PIPELINE_MODE
WIDZWIEK_ASR_PROVIDER=
WIDZWIEK_DIARIZATION_PROVIDER=
WIDZWIEK_SOUND_PROVIDER=

# Katalog na wyniki jobów (runtime, nie commitujemy)
WIDZWIEK_STORAGE_DIR=./storage

# --- Web (Next.js) — patrz też web/.env.example ---
# NEXT_PUBLIC_WORKER_URL=http://localhost:8000
