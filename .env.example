# === Widźwięk — przykładowa konfiguracja ===
# Skopiuj do .env (worker) i web/.env.local (frontend). NIE commituj .env.

# --- Worker (Python / FastAPI) ---
# Adres, na którym nasłuchuje worker
WIDZWIEK_HOST=127.0.0.1
WIDZWIEK_PORT=8000
# CORS: skąd frontend może wołać API (lokalnie Next.js dev)
WIDZWIEK_CORS_ORIGINS=http://localhost:3000
# Wybór silników AI (na PoC: "mock"). TBD: "whisper", "pyannote", "yamnet"
WIDZWIEK_ASR_PROVIDER=mock
WIDZWIEK_DIARIZATION_PROVIDER=mock
WIDZWIEK_SOUND_PROVIDER=mock
# Katalog na wyniki jobów (runtime, nie commitujemy)
WIDZWIEK_STORAGE_DIR=./storage

# --- Klucze API modeli (puste na PoC — uzupełnić przy integracji) ---
# OPENAI_API_KEY=
# HUGGINGFACE_TOKEN=

# --- Web (Next.js) — patrz też web/.env.example ---
# NEXT_PUBLIC_WORKER_URL=http://localhost:8000
