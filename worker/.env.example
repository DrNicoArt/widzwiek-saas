# Worker (Python / FastAPI) — skopiuj do worker/.env
WIDZWIEK_HOST=127.0.0.1
WIDZWIEK_PORT=8000
WIDZWIEK_CORS_ORIGINS=http://localhost:3000

# === Tryb pipeline ===
# mock = pełna symulacja (bez kluczy API); api = realna transkrypcja
PIPELINE_MODE=mock

# === OpenAI (wymagane tylko dla PIPELINE_MODE=api) ===
# Klucz TYLKO tutaj, nigdy w kodzie:
OPENAI_API_KEY=
# Model transkrypcji (whisper-1 zwraca segmenty z czasami — zalecany):
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# === Nadpisania per-etap (zaawansowane, opcjonalne) ===
# Domyślnie wynikają z PIPELINE_MODE. Zostaw puste, jeśli nie wiesz.
WIDZWIEK_ASR_PROVIDER=
WIDZWIEK_DIARIZATION_PROVIDER=
WIDZWIEK_SOUND_PROVIDER=

# Zrzut wyników jobów (runtime, nie commitujemy)
WIDZWIEK_STORAGE_DIR=./storage
